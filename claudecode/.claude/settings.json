{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus",
  "outputStyle": "Concise",
  "language": "english",
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Thinking",
      "Analyzing",
      "Building",
      "Testing"
    ]
  },
  "effortLevel": "high",
  "showTurnDuration": false,
  "defaultMode": "bypassPermissions",
  "skipDangerousModePermissionPrompt": true
}
