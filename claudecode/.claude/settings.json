{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "Concise",
  "language": "english",
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Thinking",
      "Analyzing",
      "Building",
      "Testing"
    ]
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "showTurnDuration": false,
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "auto"
  }
}
